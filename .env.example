# Database
POSTGRES_USER=appilico
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_CONNECTION_STRING=Host=postgres;Database=appilicodb;Username=appilico;Password=CHANGE_ME_STRONG_PASSWORD;

# JWT
JWT_SECRET=CHANGE_ME_AT_LEAST_32_CHARS_RANDOM_STRING

# Production feature flags
SWAGGER_ENABLED=true
STRIPE_ENABLED=false
AZURE_STORAGE_ENABLED=false
EMAIL_ENABLED=false

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Stripe (required only when STRIPE_ENABLED=true)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=aud
STRIPE_STARTER_PRICE_ID=
STRIPE_PROFESSIONAL_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=
STRIPE_WEBHOOK_TOLERANCE_SECONDS=300

# Azure Blob Storage (required only when AZURE_STORAGE_ENABLED=true)
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER_NAME=visuals
AZURE_STORAGE_MAX_FILE_SIZE_BYTES=52428800
AZURE_STORAGE_SAS_EXPIRY_MINUTES=30

# SMTP email (required only when EMAIL_ENABLED=true)
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=
EMAIL_FROM_EMAIL=noreply@appilico.com
EMAIL_FROM_NAME=Appilico
EMAIL_CLIENT_BASE_URL=https://appilico.com
EMAIL_NOTIFY_EMAIL=info@appilico.com.au
EMAIL_QUEUE_CAPACITY=100
