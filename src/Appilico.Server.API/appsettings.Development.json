{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=appilicodb_dev;Username=appilico;Password=development-only-password"
  },
  "Cloudinary": {
    "CloudName": "will-be-overridden-by-user-secrets",
    "ApiKey": "will-be-overridden-by-user-secrets",
    "ApiSecret": "will-be-overridden-by-user-secrets"
  },
  "JWT": {
    "Secret": "DevelopmentOnlyJwtSecretForLocalRuns12345",
    "Issuer": "Appilico.Server",
    "Audience": "Appilico.Client",
    "ExpirationInMinutes": 60,
    "RefreshTokenExpirationInDays": 7
  },
  "Swagger": {
    "Enabled": true
  },
  "Stripe": {
    "Enabled": false,
    "Currency": "aud",
    "WebhookToleranceSeconds": 300
  },
  "AzureStorage": {
    "Enabled": false,
    "ContainerName": "visuals",
    "MaxFileSizeBytes": 52428800,
    "SasExpiryMinutes": 30
  },
  "Email": {
    "Enabled": false,
    "SmtpPort": 587,
    "FromEmail": "noreply@appilico.com",
    "FromName": "Appilico",
    "ClientBaseUrl": "https://appilico.com",
    "NotifyEmail": "info@appilico.com.au",
    "QueueCapacity": 100
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
