{
  "ConnectionStrings": {
    "DefaultConnection": "will-be-overridden-by-user-secrets"
  },
  "Cloudinary": {
    "CloudName": "will-be-overridden-by-user-secrets",
    "ApiKey": "will-be-overridden-by-user-secrets",
    "ApiSecret": "will-be-overridden-by-user-secrets"
  },
  "JWT": {
    "Secret": "will-be-overridden-by-user-secrets",
    "Issuer": "AppilicoShopServer",
    "Audience": "Appilico.Client",
    "ExpirationInMinutes": 60,
    "RefreshTokenExpirationInDays": 7
  },
  "Swagger": {
    "Enabled": true
  },
  "Storefront": {
    "EngineName": "AppilicoShopServer",
    "StorefrontKey": "default",
    "StorefrontMode": "single-store",
    "StoreName": "Appilico Shop",
    "Tagline": "A configurable buy-and-sell storefront powered by AppilicoShopServer",
    "LogoUrl": "",
    "FaviconUrl": "",
    "SupportEmail": "info@appilico.com.au",
    "SupportPhone": "",
    "TimeZone": "Australia/Perth",
    "ApiBasePath": "/api",
    "PublicBaseUrl": "https://api.appilico.com",
    "Currency": "AUD",
    "Country": "AU",
    "DefaultLocale": "en-AU",
    "SupportedLocales": [
      "en-AU",
      "en-US"
    ],
    "ThemePreset": "system",
    "LayoutPreset": "commerce-standard",
    "ProductCardStyle": "image-first",
    "ThemeColors": {
      "background": "#f8fafc",
      "surface": "#ffffff",
      "text": "#111827",
      "mutedText": "#64748b",
      "primary": "#2563eb",
      "primaryText": "#ffffff",
      "accent": "#14b8a6",
      "border": "#e2e8f0",
      "success": "#16a34a",
      "warning": "#f59e0b",
      "danger": "#dc2626"
    },
    "TypographyTokens": {
      "headingFont": "Inter, system-ui, sans-serif",
      "bodyFont": "Inter, system-ui, sans-serif",
      "baseFontSize": "16px",
      "headingWeight": "700",
      "bodyWeight": "400"
    },
    "SpacingTokens": {
      "containerMaxWidth": "1200px",
      "sectionGap": "48px",
      "cardRadius": "8px",
      "buttonRadius": "6px"
    },
    "HomepageSections": [
      "hero",
      "featuredProducts",
      "categoryRail",
      "offers",
      "newsletter"
    ],
    "AllowGuestCheckout": true,
    "EnableStoreContextHeaders": true,
    "StoreContextHeaderName": "X-Storefront-Key",
    "StoreContextResolutionStrategy": "single-store-default",
    "SupportsMultiStore": false,
    "DefaultSeoTitle": "Appilico Shop",
    "DefaultSeoDescription": "A reusable buy-and-sell storefront powered by AppilicoShopServer.",
    "SeoKeywords": [
      "commerce",
      "storefront",
      "buy and sell"
    ],
    "NavigationLinks": [
      { "Id": "home", "Label": "Home", "Path": "/", "Slot": "primary", "SortOrder": 10 },
      { "Id": "catalog", "Label": "Shop", "Path": "/products", "Slot": "primary", "SortOrder": 20 },
      { "Id": "categories", "Label": "Categories", "Path": "/categories", "Slot": "primary", "SortOrder": 30 },
      { "Id": "offers", "Label": "Offers", "Path": "/offers", "Slot": "primary", "SortOrder": 40 },
      { "Id": "account", "Label": "Account", "Path": "/account", "Slot": "account", "SortOrder": 10, "RequiresAuth": true },
      { "Id": "orders", "Label": "Orders", "Path": "/account/orders", "Slot": "account", "SortOrder": 20, "RequiresAuth": true },
      { "Id": "contact", "Label": "Contact", "Path": "/contact", "Slot": "footer", "SortOrder": 10 },
      { "Id": "blog", "Label": "Blog", "Path": "/blog", "Slot": "footer", "SortOrder": 20 }
    ],
    "SocialLinks": [],
    "LegalLinks": [
      { "Id": "privacy", "Label": "Privacy", "Url": "/privacy" },
      { "Id": "terms", "Label": "Terms", "Url": "/terms" },
      { "Id": "returns", "Label": "Returns", "Url": "/returns" }
    ],
    "ShippingStrategy": "configured-by-server",
    "TaxStrategy": "configured-by-server",
    "ReturnsPolicyUrl": "/returns",
    "TermsUrl": "/terms",
    "PrivacyUrl": "/privacy"
  },
  "Email": {
    "Enabled": false,
    "SmtpHost": "will-be-overridden-by-user-secrets",
    "SmtpPort": 587,
    "SmtpUser": "will-be-overridden-by-user-secrets",
    "SmtpPass": "will-be-overridden-by-user-secrets",
    "FromEmail": "noreply@appilico.com",
    "FromName": "Appilico",
    "ClientBaseUrl": "https://appilico.com",
    "NotifyEmail": "info@appilico.com.au",
    "QueueCapacity": 100
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Real-IP",
    "ClientIdHeader": "X-ClientId",
    "HttpStatusCode": 429,
    "GeneralRules": [
      {
        "Endpoint": "*",
        "Period": "1m",
        "Limit": 100
      },
      {
        "Endpoint": "post:/api/auth/login",
        "Period": "1m",
        "Limit": 5
      },
      {
        "Endpoint": "post:/api/auth/register",
        "Period": "1m",
        "Limit": 3
      },
      {
        "Endpoint": "post:/api/waitlist/subscribe",
        "Period": "1m",
        "Limit": 5
      },
      {
        "Endpoint": "post:/api/contact",
        "Period": "1m",
        "Limit": 5
      }
    ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "Stripe": {
    "Enabled": false,
    "SecretKey": "will-be-overridden-by-user-secrets",
    "PublishableKey": "will-be-overridden-by-user-secrets",
    "WebhookSecret": "will-be-overridden-by-user-secrets",
    "Currency": "aud",
    "StarterPriceId": "will-be-overridden-by-user-secrets",
    "ProfessionalPriceId": "will-be-overridden-by-user-secrets",
    "EnterprisePriceId": "will-be-overridden-by-user-secrets",
    "WebhookToleranceSeconds": 300
  },
  "AzureStorage": {
    "Enabled": false,
    "ConnectionString": "will-be-overridden-by-user-secrets",
    "ContainerName": "visuals",
    "MaxFileSizeBytes": 52428800,
    "SasExpiryMinutes": 30,
    "AllowedContentTypes": [
      "application/octet-stream",
      "application/zip",
      "application/x-zip-compressed",
      "application/vnd.ms-powerbi.visual",
      "image/jpeg",
      "image/png",
      "image/webp"
    ]
  }
}
